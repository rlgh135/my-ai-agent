# ══════════════════════════════════════════════════════════════
#  AI Agent Web — 환경변수 설정 예시
#  이 파일을 복사하여 .env.local 로 만든 뒤 필요한 값을 채워주세요.
#  cp .env.example .env.local
#
#  현재 모든 설정은 vite.config.js 에 하드코딩되어 있습니다.
#  백엔드 주소를 바꾸려면 vite.config.js 의 server.proxy.target 을 수정하세요.
# ══════════════════════════════════════════════════════════════


# ── 백엔드 API 주소 ───────────────────────────────────────────
# 개발 서버 프록시 대상 (vite.config.js 참고)
# 기본값: http://127.0.0.1:8000
# 변경 시 vite.config.js의 server.proxy['/api'].target 도 함께 수정하세요.
VITE_API_BASE_URL=http://127.0.0.1:8000


# ── 개발 서버 포트 ────────────────────────────────────────────
# 기본값: 5173 (vite.config.js에 설정됨)
# 변경 시 agent-server/.env 의 CORS_ORIGINS 에도 해당 포트를 추가하세요.
# VITE_PORT=5173
