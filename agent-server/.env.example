# ──────────────────────────────────────────────
# AI Agent Server — 환경변수 설정 예시
# 이 파일을 .env로 복사 후 실제 값을 채워주세요
# cp .env.example .env
# ──────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_NAME="AI Agent Server"
DEBUG=false
HOST=127.0.0.1
PORT=8000

# ── Claude API (필수) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=8192

# ── Database (PostgreSQL) ────────────────────
# 형식: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://agent_user:qkrrlgh2!@localhost:5432/ai_agent

# ── Vault 암호화 키 ───────────────────────────
# 최초 실행 시 자동 생성됩니다. 수동 설정 시 아래에 입력
VAULT_KEY=

# ── 허용 파일 경로 (쉼표 구분) ────────────────
# Windows 경로 예시
ALLOWED_DIRECTORIES=["C:/Users/KIHOPARK/Projects","C:/Users/KIHOPARK/Documents"]

# ── 웹 검색 ──────────────────────────────────
SEARCH_PROVIDER=brave
BRAVE_API_KEY=BSA-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 작업 협의 카드 타임아웃 ────────────────────
TASK_TIMEOUT_SECONDS=300
