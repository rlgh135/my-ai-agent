# ══════════════════════════════════════════════════════════════
#  AI Agent Server — 환경변수 설정 예시
#  이 파일을 복사하여 .env 로 만든 뒤 실제 값을 채워주세요.
#  cp .env.example .env
#
#  [필수] 표시 항목은 반드시 입력해야 서비스가 정상 동작합니다.
#  그 외 항목은 기본값이 있거나 선택 기능입니다.
# ══════════════════════════════════════════════════════════════


# ── 앱 기본 설정 ──────────────────────────────────────────────
APP_NAME="AI Agent Server"
DEBUG=false
HOST=127.0.0.1
PORT=8000

# 프론트엔드 개발 서버 주소 (쉼표 없이 JSON 배열 문자열)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]


# ── Claude AI [필수] ──────────────────────────────────────────
# Anthropic Console(console.anthropic.com)에서 발급
# 앱 최초 실행 시 UI에서 입력·저장할 수도 있습니다.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx...

# 사용할 Claude 모델 ID
# 권장: claude-sonnet-4-6 | claude-opus-4-6 | claude-3-5-sonnet-20241022
CLAUDE_MODEL=claude-sonnet-4-6

# 응답 최대 토큰 수 (모델 컨텍스트 한도 내에서 설정)
CLAUDE_MAX_TOKENS=8192


# ── 데이터베이스 (PostgreSQL) [필수] ─────────────────────────
# 형식: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://agent_user:your_password@localhost:5432/agent_db


# ── Vault 암호화 키 ───────────────────────────────────────────
# API Key·비밀번호 등 민감 설정을 DB에 암호화 저장하는 데 사용됩니다.
# 비워두면 서버 최초 실행 시 자동 생성 후 이 파일에 추가됩니다.
# 한 번 생성된 키는 절대 변경하지 마세요 (기존 암호화 데이터 복호화 불가).
VAULT_KEY=


# ── 파일 시스템 ───────────────────────────────────────────────
# AI가 접근할 수 있는 경로 목록 (JSON 배열, 절대 경로)
# 비워두면 모든 경로 허용 (개발 환경 전용)
# UI 설정 패널에서도 변경 가능합니다.
# Windows 예시: ["C:/Users/me/Projects","C:/Users/me/Documents"]
# macOS  예시: ["/Users/me/projects","/Users/me/documents"]
ALLOWED_DIRECTORIES=[]


# ── 이메일 (SMTP) ─────────────────────────────────────────────
# 미설정 시 이메일 기능만 비활성화됩니다. 다른 기능에는 영향 없음.
# UI 설정 패널에서도 변경 가능합니다.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
# 발신자 표시명. 비워두면 SMTP_USER 값이 사용됩니다.
SMTP_FROM=AI 비서 <your_email@gmail.com>


# ── 웹 검색 ──────────────────────────────────────────────────
# 미설정 시 DuckDuckGo(무료, 제한적)로 자동 폴백됩니다.
# UI 설정 패널에서도 변경 가능합니다.

# 기본 검색 엔진: brave | naver | duckduckgo
SEARCH_PROVIDER=brave

# Brave Search API (영문 검색 권장)
# 발급: https://brave.com/search/api/
BRAVE_API_KEY=BSA-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Naver Search API (한국어 검색 권장)
# 발급: https://developers.naver.com/apps/#/register
NAVER_CLIENT_ID=your_naver_client_id
NAVER_API_KEY=your_naver_client_secret


# ── 사용자 정보 ───────────────────────────────────────────────
# 앱 최초 실행 시 UI에서 입력·저장됩니다.
# 직접 입력할 경우 아래에 작성하세요.
USER_NAME=


# ── 작업 협의 카드 ────────────────────────────────────────────
# 파일 생성·수정·삭제·이메일 발송 등 승인 대기 타임아웃 (초)
TASK_TIMEOUT_SECONDS=300
